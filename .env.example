# ─── VARIABLES DE ENTORNO — LANDING BASE ─────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitear el archivo .env — está en .gitignore.
# ────────────────────────────────────────────────────────────────

# ── Supabase (OBLIGATORIAS) ──────────────────────────────────────
# URL del proyecto en Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima pública (safe to expose in client bundle)
# Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=tu-clave-anon-publica

# ── Desarrollo Local ─────────────────────────────────────────────
# Slug de la tienda a previsualizar en localhost.
# Solo se usa cuando hostname es localhost/127.0.0.1.
VITE_STORE_SLUG=flores-del-corazon

# Dominio base de la plataforma SaaS.
# Los subdominios de clientes se construyen como <slug>.<PLATFORM_DOMAIN>.
# En staging, cambiar a ej: 'botaniq-staging.vercel.app'
# Default: 'botaniq.com'
VITE_PLATFORM_DOMAIN=botaniq.com

# ── Push Notifications (Fase 3) ──────────────────────────────────
# Clave pública VAPID para Web Push API.
# ─────────────────────────────────────────────────────────────────
# 🔔 3. NOTIFICACIONES PUSH (WEB-PUSH)
# ─────────────────────────────────────────────────────────────────
# Esta llave pública es segura para incluir en el frontend.
# La llave PRIVADA (VAPID_PRIVATE_KEY) NUNCA debe ir aquí.
# Debe guardarse en Supabase: Dashboard -> Edge Functions -> Secrets.
# Llave pública generada para este proyecto:
VITE_VAPID_PUBLIC_KEY=BLoarq4OU80JBE_FmUTmAAOtPMiaT0dWBvLqC9EYKG2KyBnxWZ2xRmYuvlB-m126i6BJCju70eiq5dKVVxP0UVc

# ── IMPORTANTE ───────────────────────────────────────────────────
# Las siguientes claves NUNCA deben estar en el frontend:
#   - SUPABASE_SERVICE_ROLE_KEY → solo en Edge Functions
#   - STRIPE_SECRET_KEY         → solo en Edge Functions
#   - STRIPE_WEBHOOK_SECRET     → solo en Edge Functions
#   - VAPID_PRIVATE_KEY         → solo en Supabase Secrets
