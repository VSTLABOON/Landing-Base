# ═══════════════════════════════════════════════════════════════
# Flores del Corazón — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# 1. Copia este archivo como ".env" en la raíz del proyecto
# 2. Reemplaza los valores con los de tu proyecto en Supabase
#    Dashboard > Settings > API
# 3. Reinicia Vite después de modificar este archivo (Ctrl+C → npm run dev)
# ═══════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...TU-CLAVE-ANON

# ── Feature Flags (Flujos de Checkout) ───────────────────────
# Controlan qué botones aparecen en el CartDrawer.
# Valores válidos: "true" o "false" (como strings, Vite los trata así).
#
# Caso 1 — Ambos activos (recomendado para florerías establecidas):
VITE_ENABLE_CHECKOUT=true
VITE_ENABLE_WHATSAPP=true
#
# Caso 2 — Solo WhatsApp (ideal para negocios nuevos sin pasarela):
#   VITE_ENABLE_CHECKOUT=false
#   VITE_ENABLE_WHATSAPP=true
#
# Caso 3 — Solo Checkout (si ya no necesitas WhatsApp):
#   VITE_ENABLE_CHECKOUT=true
#   VITE_ENABLE_WHATSAPP=false

# ── Tienda (Multi-tenant) ───────────────────────────────────
VITE_STORE_SLUG=flores-del-corazon

# ── Localización (Configuración geográfica) ──────────────────
# Vite inyecta automáticamente estas variables en index.html (usando %VARIABLE%)
# y en los componentes de React para adaptar los textos a cada ciudad.
VITE_STORE_CITY="Monterrey"
VITE_STORE_STATE="Nuevo León"
VITE_STORE_METRO_AREA="área metropolitana de Monterrey"
VITE_STORE_MAP_URL="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d115065.17696238075!2d-100.41846549479482!3d25.6853248386407!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86629531b437f8f5%3A0xa3d3d3ca6ac89894!2sMonterrey%2C%20N.L.!5e0!3m2!1ses-419!2smx!4v1713296185805!5m2!1ses-419!2smx"

# ── Edge Functions (solo para Supabase CLI, NO para Vite) ────
# Este valor se configura con: npx supabase secrets set ALLOWED_ORIGIN=https://tu-dominio.com
# Restringe qué dominios pueden invocar las Edge Functions (CORS).
# En desarrollo, localhost:5173 ya está permitido por defecto.

